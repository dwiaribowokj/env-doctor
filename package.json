{
  "name": "env-doctor",
  "version": "0.1.0",
  "description": "A safe CLI doctor for .env files: missing keys, duplicates, invalid URLs, empty values, and weak-looking secrets without leaking values.",
  "type": "module",
  "bin": { "env-doctor": "dist/cli.js" },
  "scripts": { "build": "tsc", "dev": "tsx src/cli.ts", "test": "vitest run", "lint": "tsc --noEmit", "prepack": "npm run build" },
  "keywords": ["cli", "dotenv", "env", "secrets", "developer-tools"],
  "license": "MIT",
  "dependencies": { "commander": "^12.1.0", "dotenv": "^16.4.5", "picocolors": "^1.0.1" },
  "devDependencies": { "@types/node": "^22.10.2", "tsx": "^4.19.2", "typescript": "^5.7.2", "vitest": "^4.1.7" },
  "engines": { "node": ">=20" },
  "files": ["dist", "README.md", "LICENSE"]
}
